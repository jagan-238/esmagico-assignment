{
  "name": "workflow-orchestration-api",
  "version": "1.0.0",
  "description": "Collaborative Workflow Orchestration System API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "setup-env": "node scripts/setup-env.mjs",
    "mongo:check": "node scripts/mongo-check.mjs",
    "start": "node src/server.js",
    "predev": "node scripts/setup-env.mjs",
    "dev": "node --watch src/server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js", "!src/server.js"]
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0"
  }
}
